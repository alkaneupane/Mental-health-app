# Copy to .env (project root). Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=paste_the_full_anon_public_jwt_here

# Supabase → Authentication → Providers:
#   • Email — ON (Supabase still stores a synthetic email per User ID). Turn “Confirm email” OFF so sign-up
#     does not send mail (avoids rate limits and missing inbox). This app does not use real email login.
#   • Anonymous — optional (only for “Continue anonymously” on the login page).

# Optional: dev only — call Supabase from the browser instead of the Vite proxy
# VITE_SUPABASE_NO_PROXY=true
